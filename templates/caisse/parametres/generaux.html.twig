{% extends 'caisse/layout.html.twig' %}

{% block title %}Paramètres Généraux - Caisse{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h4 class="mb-0"><i class="fas fa-cogs me-2"></i>Paramètres Généraux</h4>
                </div>
                <div class="card-body p-4">
                    {{ form_start(form) }}
                        <div class="mb-4">
                            <label class="form-label fw-bold">{{ form_label(form.currentPin) }}</label>
                            {{ form_widget(form.currentPin) }}
                            <div class="form-text mt-2">{{ form_help(form.currentPin) }}</div>
                            {{ form_errors(form.currentPin) }}
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">{{ form_label(form.adminPin) }}</label>
                            {{ form_widget(form.adminPin) }}
                            <div class="form-text mt-2">{{ form_help(form.adminPin) }}</div>
                            {{ form_errors(form.adminPin) }}
                        </div>
                        
                        {# Les autres champs sont rendus automatiquement par form_end #}
                        
                        <div id="sticky-save-bar" class="sticky-save-bar">
                            <div class="container">
                                <div class="row justify-content-center">
                                    <div class="col-md-6">
                                        <div class="d-grid">
                                            {{ form_widget(form.save, {'attr': {'class': 'btn btn-primary btn-lg shadow'}}) }}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    {{ form_end(form) }}
                </div>
            </div>

            <div class="card shadow-sm border-danger mt-4">
                <div class="card-header bg-danger text-white py-3">
                    <h5 class="mb-0"><i class="fas fa-exclamation-triangle me-2"></i>Zone de Danger</h5>
                </div>
                <div class="card-body p-4 text-center">
                    <p class="text-danger mb-3">
                        <strong>Attention :</strong> Cette section permet de réinitialiser la base de données.
                    </p>
                    <a href="{{ path('app_razbase_index') }}" class="btn btn-outline-danger w-100">
                        <i class="fas fa-trash-alt me-2"></i>Réinitialiser la Base de Données
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .sticky-save-bar {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        background: white;
        padding: 1rem;
        box-shadow: 0 -4px 10px rgba(0,0,0,0.1);
        z-index: 1050;
        transform: translateY(100%);
        transition: transform 0.3s ease-out;
        border-top: 1px solid #dee2e6;
    }
    
    .sticky-save-bar.visible {
        transform: translateY(0);
    }
    
    /* Ensure content is not hidden behind the bar when scrolled to bottom */
    body {
        padding-bottom: 80px;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const form = document.querySelector('form[name="form"]');
        const stickyBar = document.getElementById('sticky-save-bar');
        
        if (form && stickyBar) {
            const showStickyBar = () => {
                stickyBar.classList.add('visible');
            };

            // Detect changes on all input types
            form.addEventListener('change', showStickyBar);
            form.addEventListener('input', showStickyBar);
            
            // Also handle custom checkboxes/switches if any
            const inputs = form.querySelectorAll('input, select, textarea');
            inputs.forEach(input => {
                input.addEventListener('change', showStickyBar);
                input.addEventListener('input', showStickyBar);
            });
        }
    });
</script>
{% endblock %}
