{% extends 'caisse/layout.html.twig' %}

{% block title %}Impression Etiquettes Expéditeur - Caisse{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h3 mb-0 text-gray-800">Impression Etiquettes Expéditeur</h2>
        <div>
            <button type="button" class="btn btn-primary" id="btn-print-action">
                <i class="fas fa-print me-2"></i>Imprimer
            </button>
            <form action="{{ path('app_caisse_impressions_expediteur_print') }}" method="post" id="print-form" class="d-none" target="_blank">
                <input type="hidden" name="skipped_indices" id="hidden-skipped-indices">
                <input type="hidden" name="quantity" id="hidden-quantity">
            </form>
        </div>
    </div>

    <div class="row">
        <!-- Left Column: Settings -->
        <div class="col-md-4">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Paramètres</h6>
                </div>
                <div class="card-body">
                    <div class="form-group">
                        <label for="quantity-input">Quantité d'étiquettes</label>
                        <input type="number" class="form-control" id="quantity-input" value="1" min="1">
                        <small class="form-text text-muted">Nombre d'étiquettes "Expéditeur" à imprimer.</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Grid -->
        <div class="col-md-8">
            <div class="card shadow mb-4 sticky-top" style="top: 20px; z-index: 900;">
                <div class="card-header py-3 d-flex justify-content-between align-items-center">
                    <h6 class="m-0 font-weight-bold text-primary">Aperçu Planche</h6>
                    <button type="button" class="btn btn-sm btn-outline-secondary" id="btn-reset-grid">
                        <i class="fas fa-undo me-1"></i>Réinitialiser
                    </button>
                </div>
                <div class="card-body">
                    <p class="text-muted small mb-3">
                        Cliquez sur les cases pour marquer les étiquettes <strong>déjà utilisées</strong> (en gris).<br>
                        Les étiquettes à imprimer rempliront les cases <strong>libres</strong> (en bleu).
                    </p>
                    <div id="etiquette-grid-container" class="border p-3 bg-light d-flex flex-wrap justify-content-center" style="min-height: 400px; max-height: 80vh; overflow-y: auto;">
                        <!-- Grid generated by JS -->
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // State
    let skippedIndices = new Set();
    let quantity = 1;
    
    // Elements
    const quantityInput = document.getElementById('quantity-input');
    const btnPrint = document.getElementById('btn-print-action');
    const printForm = document.getElementById('print-form');
    const hiddenSkipped = document.getElementById('hidden-skipped-indices');
    const hiddenQuantity = document.getElementById('hidden-quantity');
    const gridContainer = document.getElementById('etiquette-grid-container');
    const btnResetGrid = document.getElementById('btn-reset-grid');

    // Format Data
    const format = {
        width: {{ format ? format.largeur : 0 }},
        height: {{ format ? format.hauteur : 0 }},
        margeHaut: {{ format ? format.margeHaut : 0 }},
        margeGauche: {{ format ? format.margeGauche : 0 }},
        margeBas: {{ format ? format.margeBas : 0 }},
        margeDroite: {{ format ? format.margeDroite : 0 }},
        distH: {{ format ? format.distanceHorizontale : 0 }},
        distV: {{ format ? format.distanceVerticale : 0 }}
    };

    // Initialize
    quantityInput.addEventListener('input', function() {
        quantity = parseInt(this.value) || 0;
        generateGrid();
    });
    
    btnResetGrid.addEventListener('click', () => {
        skippedIndices.clear();
        generateGrid();
    });
    
    btnPrint.addEventListener('click', function() {
        if (quantity <= 0) return;
        
        // Prepare Form
        hiddenSkipped.value = JSON.stringify(Array.from(skippedIndices));
        hiddenQuantity.value = quantity;
        
        printForm.submit();
    });

    function generateGrid() {
        gridContainer.innerHTML = '';
        if (!format.width || !format.height) return;

        const PAGE_WIDTH = 21.0;
        const PAGE_HEIGHT = 29.7;
        const pxPerCm = 20; // Scale for display

        const availableWidth = PAGE_WIDTH - format.margeGauche - format.margeDroite;
        const availableHeight = PAGE_HEIGHT - format.margeHaut - format.margeBas;

        let cols = 0;
        if (format.width > 0 && format.width <= availableWidth) {
            cols = 1 + Math.floor((availableWidth - format.width) / (format.width + format.distH));
        }
        
        let rows = 0;
        if (format.height > 0 && format.height <= availableHeight) {
            rows = 1 + Math.floor((availableHeight - format.height) / (format.height + format.distV));
        }
        
        const totalSlots = cols * rows;

        const pageDiv = document.createElement('div');
        pageDiv.style.width = (PAGE_WIDTH * pxPerCm) + 'px';
        pageDiv.style.height = (PAGE_HEIGHT * pxPerCm) + 'px';
        pageDiv.style.backgroundColor = 'white';
        pageDiv.style.border = '1px solid #ccc';
        pageDiv.style.position = 'relative';
        pageDiv.style.margin = '0 auto';
        
        let filledCount = 0;

        for (let i = 0; i < totalSlots; i++) {
            const row = Math.floor(i / cols);
            const col = i % cols;
            
            const x = format.margeGauche + (col * (format.width + format.distH));
            const y = format.margeHaut + (row * (format.height + format.distV));
            
            const cell = document.createElement('div');
            cell.style.position = 'absolute';
            cell.style.left = (x * pxPerCm) + 'px';
            cell.style.top = (y * pxPerCm) + 'px';
            cell.style.width = (format.width * pxPerCm) + 'px';
            cell.style.height = (format.height * pxPerCm) + 'px';
            cell.className = 'border d-flex align-items-center justify-content-center';
            cell.style.cursor = 'pointer';
            cell.style.fontSize = '9px';
            cell.style.userSelect = 'none';
            cell.title = `Emplacement ${i + 1}`;
            
            const isSkipped = skippedIndices.has(i);
            
            if (isSkipped) {
                cell.className += ' bg-secondary text-white opacity-50';
                cell.innerHTML = '<i class="fas fa-times"></i>';
            } else if (filledCount < quantity) {
                cell.className += ' bg-info text-white';
                filledCount++;
                cell.textContent = filledCount;
            } else {
                cell.className += ' bg-white text-dark';
            }

            cell.addEventListener('click', function() {
                if (skippedIndices.has(i)) {
                    skippedIndices.delete(i);
                } else {
                    skippedIndices.add(i);
                }
                generateGrid();
            });

            pageDiv.appendChild(cell);
        }

        gridContainer.appendChild(pageDiv);
    }

    // Initial render
    generateGrid();
});
</script>
{% endblock %}
