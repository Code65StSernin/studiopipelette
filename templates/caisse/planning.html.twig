{% extends 'caisse/layout.html.twig' %}

{% block title %}Caisse - Planning{% endblock %}

{% block body %}
    <style>
        .section-title {
            color: #d4807e;
            border-bottom: 2px solid #d4807e;
            padding-bottom: 10px;
            margin-bottom: 20px;
        }
    </style>
    <div class="container-fluid mt-4">
        <h1 class="section-title">Planning</h1>
        <div id="calendar" style="background: white; padding: 20px; border-radius: 8px;"></div>
    </div>

    <!-- Modal Creation Reservation -->
    <div class="modal fade" id="modalCreateReservation" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Nouveau rendez-vous</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div id="overlap-alert" class="alert alert-danger d-none"></div>
                    <form id="form-create-reservation">
                        <input type="hidden" id="res-start-date">
                        <div class="mb-3">
                            <label class="form-label">Client</label>
                            <div class="input-group">
                                <select class="form-select" id="select-client" style="width: 70%;">
                                    <option value="">-- Sélectionner un client --</option>
                                    {% for user in users %}
                                        <option value="{{ user.id }}">{{ user.prenom }} {{ user.nom }} ({{ user.email }})</option>
                                    {% endfor %}
                                </select>
                                <button type="button" class="btn btn-outline-secondary" id="btn-new-client">Nouveau client</button>
                            </div>
                        </div>

                        <div id="new-client-fields" class="d-none border p-3 mb-3 bg-light">
                            <h6>Nouveau Client</h6>
                            <div class="row">
                                <div class="col-md-6 mb-2">
                                    <input type="text" class="form-control" id="new-client-prenom" placeholder="Prénom">
                                </div>
                                <div class="col-md-6 mb-2">
                                    <input type="text" class="form-control" id="new-client-nom" placeholder="Nom">
                                </div>
                                <div class="col-md-6 mb-2">
                                    <input type="email" class="form-control" id="new-client-email" placeholder="Email">
                                </div>
                                <div class="col-md-6 mb-2">
                                    <input type="text" class="form-control" id="new-client-tel" placeholder="Téléphone">
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Prestations (Plusieurs choix possibles)</label>
                            <div class="row">
                                {% for tarif in tarifs %}
                                    <div class="col-md-6">
                                        <div class="form-check">
                                            <input class="form-check-input check-prestation" type="checkbox" value="{{ tarif.id }}" id="tarif-{{ tarif.id }}">
                                            <label class="form-check-label" for="tarif-{{ tarif.id }}">
                                                {{ tarif.nom }} ({{ tarif.dureeMinutes }} min - {{ tarif.tarif }}€)
                                            </label>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>

                        <div id="pin-field" class="d-none border p-3 mb-3 bg-warning bg-opacity-10">
                            <label class="form-label text-danger font-weight-bold">Code PIN Administrateur requis</label>
                            <input type="password" class="form-control" id="admin-pin" placeholder="Saisir le code PIN">
                            <small class="text-muted">Ce créneau est normalement indisponible. Le code PIN permet de passer outre.</small>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="button" class="btn btn-primary" id="btn-save-reservation">Enregistrer</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.js"></script>
    <script src="https://unpkg.com/@popperjs/core@2"></script>
    <script src="https://unpkg.com/tippy.js@6"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var calendarEl = document.getElementById('calendar');
            var calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'timeGridDay',
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,timeGridDay'
                },
                events: "{{ path('app_caisse_api_creneaux') }}",
                locale: 'fr',
                selectable: true,
                selectOverlap: false,
                select: function(info) {
                    const startStr = info.startStr;
                    document.getElementById('res-start-date').value = startStr;
                    document.getElementById('overlap-alert').classList.add('d-none');
                    document.getElementById('pin-field').classList.add('d-none');
                    document.getElementById('admin-pin').value = "";
                    document.getElementById('form-create-reservation').reset();
                    document.getElementById('new-client-fields').classList.add('d-none');
                    
                    const modal = new bootstrap.Modal(document.getElementById('modalCreateReservation'));
                    modal.show();
                    calendar.unselect();
                },
                buttonText: {
                    today:    'Aujourd\'hui',
                    month:    'Mois',
                    week:     'Semaine',
                    day:      'Jour',
                },
                allDaySlot: false,
                slotMinTime: '08:00:00',
                slotMaxTime: '20:00:00',
                height: 'auto',
                nowIndicator: true,
                eventContent: function(arg) {
                    var props = arg.event.extendedProps || {};
                    var title = arg.event.title || (props.clientName || '');
                    var isReservation = props.type === 'reservation';
                    var status = props.status || 'confirmed';
                    var html = '<div class="fc-res-content" style="position:relative; padding-right:64px;">' +
                               '<div>' + title + '</div>';
                    if (isReservation && status === 'confirmed') {
                        html += '<button class="btn btn-sm btn-warning fc-reserve-missed" ' +
                                'style="position:absolute; top:4px; right:40px; z-index:5;" ' +
                                'title="Marquer non honoré" ' +
                                'data-id="' + (props.reservationId || '') + '">' +
                                '<img src="/assets/img/lapin.png" alt="Lapin" style="width: 20px; height: 20px; vertical-align: middle;">' +
                                '</button>';
                        html += '<button class="btn btn-sm btn-primary fc-reserve-cart" ' +
                                'style="position:absolute; top:4px; right:4px; z-index:5;" ' +
                                'title="Ajouter au panier" ' +
                                'data-client-email="' + (props.clientEmail || '') + '" ' +
                                'data-prestations="' + ((props.prestations || []).join(',')) + '" ' +
                                'data-id="' + (props.reservationId || '') + '">' +
                                '<i class="fas fa-shopping-cart"></i></button>';
                    }
                    html += '</div>';
                    return { html: html };
                },
                eventDidMount: function(info) {
                    if (info.event.extendedProps.prestationsLabel) {
                        tippy(info.el, {
                            content: info.event.extendedProps.prestationsLabel,
                            placement: 'top',
                        });
                    } else if (info.event.title) {
                         tippy(info.el, {
                            content: info.event.title,
                            placement: 'top',
                        });
                    }
                    var btn = info.el.querySelector('.fc-reserve-cart');
                    if (btn) {
                        btn.addEventListener('click', function(e) {
                            e.stopPropagation();
                            var email = btn.getAttribute('data-client-email') || '';
                            var prestations = btn.getAttribute('data-prestations') || '';
                            var resId = btn.getAttribute('data-id') || '';
                            var url = '{{ path("app_caisse") }}' + '?clientEmail=' + encodeURIComponent(email) + '&tarifs=' + encodeURIComponent(prestations) + '&reservationId=' + resId;
                            window.location.href = url;
                        });
                    }

                    var btnMissed = info.el.querySelector('.fc-reserve-missed');
                    if (btnMissed) {
                        btnMissed.addEventListener('click', function(e) {
                            e.stopPropagation();
                            var resId = btnMissed.getAttribute('data-id');
                            if (confirm('Confirmer que ce rendez-vous n\'a pas été honoré ?')) {
                                fetch('/caisse/reservation/' + resId + '/missed', {
                                    method: 'POST',
                                    headers: {
                                        'X-Requested-With': 'XMLHttpRequest'
                                    }
                                }).then(response => response.json())
                                  .then(data => {
                                      if (data.status === 'success') {
                                          calendar.refetchEvents();
                                      } else {
                                          alert('Erreur: ' + (data.message || 'Inconnue'));
                                      }
                                  });
                            }
                        });
                    }
                }
            });
            calendar.render();

            // Gestion de la modale de création
            const btnNewClient = document.getElementById('btn-new-client');
            const newClientFields = document.getElementById('new-client-fields');
            const btnSave = document.getElementById('btn-save-reservation');
            const alertBox = document.getElementById('overlap-alert');

            if (btnNewClient) {
                btnNewClient.addEventListener('click', () => {
                    newClientFields.classList.toggle('d-none');
                    if (!newClientFields.classList.contains('d-none')) {
                        document.getElementById('select-client').value = "";
                    }
                });
            }

            if (btnSave) {
                btnSave.addEventListener('click', () => {
                    const startDate = document.getElementById('res-start-date').value;
                    const userId = document.getElementById('select-client').value;
                    const prestationIds = Array.from(document.querySelectorAll('.check-prestation:checked')).map(cb => cb.value);
                    
                    let newClientData = null;
                    if (newClientFields && !newClientFields.classList.contains('d-none')) {
                        newClientData = {
                            prenom: document.getElementById('new-client-prenom').value,
                            nom: document.getElementById('new-client-nom').value,
                            email: document.getElementById('new-client-email').value,
                            telephone: document.getElementById('new-client-tel').value
                        };
                        if (!newClientData.prenom || !newClientData.nom || !newClientData.email) {
                            alert('Veuillez remplir les champs obligatoires du nouveau client (Prénom, Nom, Email).');
                            return;
                        }
                    } else if (!userId) {
                        alert('Veuillez sélectionner un client ou en créer un nouveau.');
                        return;
                    }

                    if (prestationIds.length === 0) {
                        alert('Veuillez sélectionner au moins une prestation.');
                        return;
                    }

                    const data = {
                        date: startDate,
                        user_id: userId || null,
                        prestation_ids: prestationIds,
                        new_client: newClientData,
                        admin_pin: document.getElementById('admin-pin').value || null
                    };

                    fetch('{{ path("app_caisse_reservation_create_manual") }}', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: JSON.stringify(data)
                    }).then(response => response.json())
                    .then(result => {
                        if (result.success) {
                            const modalEl = document.getElementById('modalCreateReservation');
                            if (modalEl) {
                                const modal = bootstrap.Modal.getInstance(modalEl);
                                if (modal) modal.hide();
                            }
                            calendar.refetchEvents();
                        } else {
                            if (alertBox) {
                                alertBox.textContent = result.error;
                                alertBox.classList.remove('d-none');
                            }
                            
                            if (result.requires_pin) {
                                const pinField = document.getElementById('pin-field');
                                if (pinField) pinField.classList.remove('d-none');
                            }
                        }
                    }).catch(err => {
                        if (alertBox) {
                            alertBox.textContent = "Une erreur est survenue lors de l'enregistrement.";
                            alertBox.classList.remove('d-none');
                        }
                    });
                });
            }
        });
    </script>
{% endblock %}
