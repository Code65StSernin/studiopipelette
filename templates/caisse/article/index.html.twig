{% extends 'caisse/layout.html.twig' %}

{% block title %}Articles{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex align-items-center gap-3">
            <h1 class="mb-0">Articles</h1>
            <form action="{{ path('app_caisse_article_index') }}" method="get" class="d-flex">
                <div class="input-group">
                    <input type="text" name="q" class="form-control" placeholder="Rechercher..." value="{{ app.request.query.get('q') }}">
                    <button class="btn btn-outline-secondary" type="submit">
                        <i class="fas fa-search"></i>
                    </button>
                </div>
            </form>
        </div>
        <a href="{{ path('app_caisse_article_new') }}" class="btn btn-primary">
            <i class="fas fa-plus"></i> Nouvel article
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="bg-light">
                    <tr>
                        <th>Nom</th>
                        <th>Catégorie</th>
                        <th>Sous-catégorie</th>
                        <th>Prix</th>
                        <th>Stock</th>
                        <th>Visibilité</th>
                        <th>Statut</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for article in articles %}
                    <tr>
                        <td class="align-middle fw-bold">
                            {{ article.nom }}
                            {% if article.gencod %}
                                <br><small class="text-muted">{{ article.gencod }}</small>
                            {% endif %}
                        </td>
                        <td class="align-middle">{{ article.categorie ? article.categorie.nom : '-' }}</td>
                        <td class="align-middle">{{ article.sousCategorie ? article.sousCategorie.nom : '-' }}</td>
                        <td class="align-middle">
                            {% set prix = 0 %}
                            {% if article.tailles is not empty %}
                                {% set prix = article.tailles[0].prix|default(0) %}
                            {% endif %}
                            {{ prix|number_format(2, ',', ' ') }} €
                        </td>
                        <td class="align-middle">
                            {% set stockTotal = 0 %}
                            {% for taille in article.tailles %}
                                {% set stockTotal = stockTotal + taille.stock %}
                            {% endfor %}
                            <span class="badge {% if stockTotal > 0 %}bg-success{% else %}bg-danger{% endif %}">
                                {{ stockTotal }}
                            </span>
                        </td>
                        <td class="align-middle">
                            {% if article.visibilite == 'online' %}
                                <span class="badge bg-info">En ligne</span>
                            {% elseif article.visibilite == 'shop' %}
                                <span class="badge bg-warning text-dark">Boutique</span>
                            {% elseif article.visibilite == 'both' %}
                                <span class="badge bg-success">Les deux</span>
                            {% endif %}
                        </td>
                        <td class="align-middle">
                            <div class="form-check form-switch">
                                <input class="form-check-input toggle-actif" type="checkbox" role="switch" id="actif_{{ article.id }}" data-url="{{ path('app_caisse_article_toggle_actif', {'id': article.id}) }}" {% if article.actif %}checked{% endif %}>
                                <label class="form-check-label" for="actif_{{ article.id }}">
                                    {% if article.actif %}Actif{% else %}Inactif{% endif %}
                                </label>
                            </div>
                        </td>
                        <td class="align-middle text-end">
                            <a href="{{ path('app_caisse_article_edit', {'id': article.id}) }}" class="btn btn-sm btn-outline-primary me-1" title="Modifier">
                                <i class="fas fa-edit"></i>
                            </a>
                            <form method="post" action="{{ path('app_caisse_article_delete', {'id': article.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet article ?');" style="display: inline-block;">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ article.id) }}">
                                <button class="btn btn-sm btn-outline-danger" title="Supprimer">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" class="text-center py-4">Aucun article trouvé</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    
    <div class="mt-3">
        {{ knp_pagination_render(articles) }}
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('.toggle-actif').forEach(switchInput => {
                switchInput.addEventListener('change', async function() {
                    const url = this.dataset.url;
                    const label = this.nextElementSibling;
                    const isChecked = this.checked;
                    
                    // Disable while loading
                    this.disabled = true;
                    
                    try {
                        const response = await fetch(url, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'X-Requested-With': 'XMLHttpRequest'
                            }
                        });
                        
                        if (!response.ok) {
                            throw new Error('Network response was not ok');
                        }

                        const data = await response.json();
                        
                        if (data.success) {
                            label.textContent = data.actif ? 'Actif' : 'Inactif';
                        } else {
                            // Revert if failed
                            this.checked = !isChecked;
                            alert('Erreur lors de la mise à jour : ' + (data.message || 'Erreur inconnue'));
                        }
                    } catch (error) {
                        console.error('Error:', error);
                        this.checked = !isChecked;
                        alert('Une erreur est survenue lors de la communication avec le serveur.');
                    } finally {
                        this.disabled = false;
                    }
                });
            });
        });
    </script>
{% endblock %}
