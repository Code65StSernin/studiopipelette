<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Ticket de caisse #{{ vente.dateVente|date('ymd') }}-{{ vente.id }}</title>
    <style>
        /* Base Styles */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Courier New', Courier, monospace;
            font-size: 11px;
            color: #000; /* Noir pur pour thermique */
            line-height: 1.2;
            background-color: #f0f2f5;
            font-weight: bold; /* Tout le ticket en gras */
        }

        /* Screen Only Logic */
        @media screen {
            .ticket-container {
                width: 54mm; /* Retour à 54mm pour l'écran */
                margin: 20px auto 140px;
                background: white;
                padding: 4mm;
                box-shadow: 0 4px 15px rgba(0,0,0,0.2);
            }
            .actions-container {
                position: fixed;
                bottom: 0;
                left: 0;
                right: 0;
                background: white;
                padding: 15px;
                box-shadow: 0 -2px 15px rgba(0,0,0,0.1);
                z-index: 1000;
                text-align: center;
            }
        }

        /* Print Only Logic */
        @media print {
            @page {
                margin: 0;
                size: 50mm auto; /* Largeur de page réduite pour forcer le navigateur à ne pas déborder */
            }
            body {
                background-color: white !important;
                width: 50mm !important;
                height: auto !important;
                min-height: 0 !important;
                overflow: visible !important;
            }
            .ticket-container {
                width: 100% !important;
                margin: 0 !important;
                padding: 1mm 4mm 1mm 1mm !important; /* Marge droite importante (4mm) pour éviter la troncature */
                background: white !important;
                box-shadow: none !important;
                height: auto !important;
                min-height: 0 !important;
                display: block !important;
            }
            .actions-container {
                display: none !important;
            }
            /* Forcer le noir pur à l'impression */
            * {
                color: #000 !important;
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }
        }

        /* Shared Ticket Layout */
        .text-center { text-align: center; }
        .text-right { text-align: right; }
        .text-left { text-align: left; }
        .bold { font-weight: bold; }
        .uppercase { text-transform: uppercase; }

        .header {
            margin-bottom: 12px;
        }
        
        .logo-img {
            display: block; 
            margin: 0 auto 8px; 
            max-width: 90%; 
            height: auto;
            filter: contrast(1.5) brightness(0.8); /* Accentuer pour thermique */
        }

        .separator {
            border-top: 1.5px dashed #000; /* Un peu plus épais */
            margin: 6px 0;
            height: 0;
            width: 100%;
        }

        .info-row {
            display: flex;
            justify-content: space-between;
        }

        .items-table {
            width: 100%;
            border-collapse: collapse;
            margin: 8px 0;
        }
        
        .items-table td {
            vertical-align: top;
            padding: 2px 0;
        }

        .col-qty { width: 12%; }
        .col-name { width: 63%; }
        .col-price { width: 25%; text-align: right; }

        .total-section {
            font-size: 13px;
            margin: 10px 0;
        }

        .total-row {
            display: flex;
            justify-content: space-between;
            font-weight: bold;
            font-size: 15px;
            margin-top: 4px;
        }

        .footer {
            margin-top: 12px;
            font-size: 9px;
            line-height: 1.4;
        }
        
        .tva-mention {
            margin: 8px 0;
            font-style: italic;
            font-size: 9px;
        }

        .print-btn {
            display: inline-block;
            width: 250px;
            padding: 12px;
            background: #333;
            color: white;
            text-align: center;
            text-decoration: none;
            font-family: sans-serif;
            font-weight: bold;
            cursor: pointer;
            border: none;
            border-radius: 4px;
        }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"></script>
</head>
<body>

    <div class="actions-container">
        <button class="print-btn" onclick="window.print()">
            <i class="fas fa-print"></i> Imprimer le ticket
        </button>
    </div>

    <div class="ticket-container">
        <!-- En-tête Société -->
        <div class="header text-center">
            <div class="bold uppercase" style="font-size: 16px; margin-bottom: 5px;">{{ societe.nom }}</div>
            <div>{{ societe.adresse }}</div>
            <div>{{ societe.codePostal }} {{ societe.ville }}</div>
            {% if societe.telephone %}<div>{{ societe.telephone }}</div>{% endif %}
            {% if societe.email %}<div>{{ societe.email }}</div>{% endif %}
        </div>

        <div class="separator"></div>

        <!-- Info Ticket -->
        <div class="info-row text-center">
            <span>Le {{ vente.dateVente|date('d/m/Y') }}</span>
            <span>Ticket {{ vente.dateVente|date('ymd') }}-{{ vente.id }}</span>
        </div>

        <div class="separator"></div>

        <!-- Info Vendeur / Client -->
        {% if app.user %}
            <div class="text-center">Servi par {{ app.user.prenom|default('Vendeur') }}</div>
        {% endif %}
        
        {% if vente.client %}
            <div class="separator"></div>
            <div class="text-center">Client: {{ vente.client.prenom }} {{ vente.client.nom|upper }}</div>
        {% endif %}

        <div class="separator"></div>

        <!-- Ticket # / ID Unique -->
        <div class="text-left" style="margin: 10px 0;">
            Ticket # : {{ vente.dateVente|date('ymd') }}-{{ vente.id }}
            {% if vente.montantTotal < 0 and vente.avoir %}
                <br>AVOIR {{ vente.avoir.code }}
                <br>Valable jusqu'au {{ vente.dateVente|date_modify("+6 months")|date('d/m/Y') }}
                <div class="text-center" style="margin-top: 10px;">
                    <svg id="barcode-avoir"></svg>
                    <script>
                        JsBarcode("#barcode-avoir", "{{ vente.avoir.code }}", {
                            format: "CODE128",
                            displayValue: true,
                            fontSize: 14,
                            height: 35,
                            width: 1.2,
                            margin: 0
                        });
                    </script>
                </div>
            {% endif %}
        </div>

        <!-- Articles -->
        <table class="items-table">
            {% set totalArticles = 0 %}
            {% for ligne in vente.ligneVentes %}
                {% set lineTotal = ligne.prixUnitaire * ligne.quantite %}
                {% set totalArticles = totalArticles + lineTotal %}
                <tr>
                    <td class="col-qty">{{ ligne.quantite }}</td>
                    <td class="col-name">{{ ligne.nom }}</td>
                    <td class="col-size">
                        {# Gestion taille si applicable, sinon vide #}
                    </td>
                    <td class="col-price">{{ lineTotal|number_format(2, '.', '') }}</td>
                </tr>
            {% endfor %}
        </table>

        <div class="separator"></div>

        <!-- Totaux -->
        <div class="total-section">
            {% if (totalArticles - vente.montantTotal)|abs > 0.01 %}
                <div class="info-row">
                    <span>Total Articles</span>
                    <span>EUR {{ totalArticles|number_format(2, '.', '') }}</span>
                </div>
                <div class="info-row">
                    <span>Dont Avoir</span>
                    <span>- EUR {{ (totalArticles - vente.montantTotal)|number_format(2, '.', '') }}</span>
                </div>
            {% endif %}
            <div class="total-row">
                <span>TOTAL A PAYER</span>
                <span>EUR {{ vente.montantTotal|number_format(2, '.', '') }}</span>
            </div>
        </div>

        <!-- Mention TVA -->
        <div class="tva-mention text-left">
            TVA non applicable, art. 293 B du CGI
        </div>

        <div class="separator"></div>

        <!-- Paiement -->
        <div class="text-center" style="margin: 15px 0;">
            Payé en {{ vente.modePaiement|upper }}<br>
            {# Pour l'instant on n'a pas le détail Donné/Rendu en base, on affiche juste le total #}
            Montant : {{ vente.montantTotal|number_format(2, '.', '') }} EUR
        </div>

        <!-- Footer -->
        <div class="footer text-center">
            <p style="font-size: 14px; font-weight: bold;">Merci de votre visite.<br>A bientôt!</p>
            
            {% if societe.siret %}
                <div style="margin-top: 10px;">
                    SIRET {{ societe.siret }}
                    {% if societe.ville %} - RCS {{ societe.ville }}{% endif %}
                </div>
            {% endif %}
            
            <div style="margin-top: 5px;">www.studiopipelette.fr</div>
        </div>
    </div>

    <script>
        // Lancer l'impression automatiquement au chargement
        window.onload = function() {
            setTimeout(() => {
                window.print();
            }, 500);
        };
    </script>
</body>
</html>
